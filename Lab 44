import numpy as np

def softmax_stable(x):
    x = np.array(x)
    exp_x = np.exp(x - np.max(x))
    return exp_x / np.sum(exp_x)

scores = np.array([2.0, 1.0, 0.1])

probs = softmax_stable(scores)

print("Scores:", scores)
print("Softmax Probabilities:", probs)
print("Sum of probabilities:", np.sum(probs))
